function Create-ExcelDevis {
    try {
        $ClientName = [Microsoft.VisualBasic.Interaction]::InputBox("Entrez le Nom du Client :", "Nouveau Devis", "")
        if ($ClientName -eq "") { $ClientName = "CLIENT DIVERS" }
        $Excel = New-Object -ComObject Excel.Application; $Excel.Visible = $true; $Wb = $Excel.Workbooks.Add()
        $ShData = $Wb.Worksheets.Add(); $ShData.Name = "Base_Articles"
        $ShData.Range("A1").Value2 = "PRESTATION"; $ShData.Range("B1").Value2 = "PRIX"
        $ShData.Range("A2").Value2 = "Forfait Reinstallation Windows"; $ShData.Range("B2").Value2 = 80
        $ShData.Range("A3").Value2 = "Nettoyage Virus / Malware"; $ShData.Range("B3").Value2 = 65
        $ShData.Range("A4").Value2 = "Recuperation de Donnees"; $ShData.Range("B4").Value2 = 90
        $Sh = $Wb.Worksheets.Item(2); $Sh.Name = "Devis_Jamie"; $Sh.Select()
        $Sh.Range("A1").Value2 = "ENTREPRISE JAMIE"; $Sh.Range("A1").Font.Size = 24; $Sh.Range("A1").Font.Bold = $true
        $Sh.Range("E1").Value2 = "DEVIS DESTINE A :"; $Sh.Range("E1").Font.Bold = $true
        $Sh.Range("E2").Value2 = $ClientName; $Sh.Range("E2").Font.Size = 14; $Sh.Range("E2").Font.Color = 0xFF0000
        $Sh.Range("E6").Value2 = "DATE :"; $Sh.Range("F6").Formula = "=TODAY()"
        $Sh.Range("A12").Value2 = "Prestation"; $Sh.Range("B12").Value2 = "Qte"; $Sh.Range("C12").Value2 = "Prix Unit."; $Sh.Range("D12").Value2 = "Total HT"
        $Sh.Range("A12:D12").Interior.Color = 0x333333; $Sh.Range("A12:D12").Font.Color = 0xFFFFFF
        for($i=13; $i -le 35; $i++) {
            $CellA = "A" + $i; $CellB = "B" + $i; $CellC = "C" + $i; $CellD = "D" + $i
            $Range = $Sh.Range($CellA); $Range.Validation.Delete()
            $Range.Validation.Add([int]3, [int]1, [int]1, '=Base_Articles!$A$2:$A$10')
            $Sh.Range($CellC).Formula = "=IFERROR(VLOOKUP(" + $CellA + ",Base_Articles!A:B,2,FALSE),0)"
            $Sh.Range($CellD).Formula = "=IF(OR(" + $CellB + "="""", " + $CellC + "=""""), """", " + $CellB + "*" + $CellC + ")"
        }
    } catch { [System.Windows.Forms.MessageBox]::Show("Erreur Excel. Est-il bien installe ?") }
}

function Run-Cmd($t, $c) { Start-Process cmd -ArgumentList "/c title $t && color 0B && echo --- $t --- && echo. && $c && echo. && pause" }

function Add-Section($txt, $x, $y, $col) {
    $l = New-Object System.Windows.Forms.Label; $l.Text = $txt; $l.Location = New-Object System.Drawing.Point($x, $y)
    $l.Size = New-Object System.Drawing.Size(380, 30); $l.Font = $FontHeader; $l.ForeColor = $col
    $Line = New-Object System.Windows.Forms.Label; $Line.BackColor = $col
    $newY = [int]($y + 32); $Line.Location = New-Object System.Drawing.Point($x, $newY); $Line.Size = New-Object System.Drawing.Size(380, 2)
    $Form.Controls.Add($l); $Form.Controls.Add($Line)
}

function Add-Btn($txt, $x, $y, $desc, $cmd, $textColor="White") {
    $b = New-Object System.Windows.Forms.Button; $b.Text = $txt.ToUpper(); $b.Location = New-Object System.Drawing.Point($x, $y)
    $b.Size = New-Object System.Drawing.Size(380, 42); $b.BackColor = "#151515"
    $b.ForeColor = [System.Drawing.ColorTranslator]::FromHtml($textColor); $b.FlatStyle = "Flat"; $b.Font = $FontBtn; $b.FlatAppearance.BorderSize = 0
    $b.Tag = @{ Desc=$desc; OriginColor=$textColor }
    $b.Add_MouseEnter({ $script:LblDesc.Text = $this.Tag.Desc; $this.ForeColor = "#00E5FF" })
    $b.Add_MouseLeave({ $script:LblDesc.Text = "..."; $this.ForeColor = [System.Drawing.ColorTranslator]::FromHtml($this.Tag.OriginColor) })
    $b.Add_Click($cmd); $Form.Controls.Add($b)
}

