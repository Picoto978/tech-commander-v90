# --- LE CERVEAU PYAUTOGUI ---
$Script:RunIA = {
    if ($InIA.Text -ne "") {
        $T = $InIA.Text -replace "'", "" -replace '"', ""
        $InIA.Text = ""
        
        $script:LblDesc.Text = "IA EN REFLEXION... VEUILLEZ PATIENTER."
        $script:LblDesc.ForeColor = $C_Orange
        $Form.Refresh()

        # Prompt ultra securise avec regles de timing strictes
        $Brain = "Write a Python script to automate this: '$T'. RULES: 1. Use ONLY 'pyautogui' and 'time'. 2. MUST include 'import pyautogui, time'. 3. MUST start with 'time.sleep(1)'. 4. MUST add 'time.sleep(2)' after opening any app. 5. Output ONLY the raw Python code. NO explanations, NO markdown tags."
        
        $AiResponse = (ollama run llama3.1 "$Brain") -join "`n"
        
        # Filtre intelligent pour extraire uniquement le code Python (avec code hexa \x60 pour eviter la coupure)
        $Code = $AiResponse
        if ($AiResponse -match '(?s)\x60\x60\x60(?:python)?(.*?)\x60\x60\x60') {
            $Code = $matches[1]
        }
        $Code = $Code.Trim()
        
        if ($Code -ne "") {
            $script:LblDesc.Text = "EXECUTION DU SCRIPT PYAUTOGUI..."
            $script:LblDesc.ForeColor = $C_Green
            $Form.Refresh()
            
            $PyFile = "$env:TEMP\ai_mouse_action.py"
            $Code | Out-File -FilePath $PyFile -Encoding UTF8
            
            # Execution avec fenetre de controle rouge si ca plante
            $CmdArgs = "/c title IA_MOUSE && color 0A && echo === SCRIPT PYTHON === && type `"$PyFile`" && echo. && echo =================== && python `"$PyFile`" || (color 4F && echo. && echo ERREUR PYTHON DETECTEE !) & pause"
            Start-Process cmd.exe -ArgumentList $CmdArgs
        } else {
            $script:LblDesc.Text = "ERREUR: L'IA N'A RIEN REPONDU."
            $script:LblDesc.ForeColor = $C_Red
        }
    }
}

